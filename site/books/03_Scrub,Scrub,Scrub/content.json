    {
      "id": "0-1",
      "extendText": [
        {
          "en": "It's Bella and Ducky!",
          "zh": "这是贝拉和达基！"
        },
        {
          "en": "Where are they?",
          "zh": "他们在哪里？"
        },
        {
          "en": "Are they in the kitchen?",
          "zh": "他们在厨房吗？"
        },
        {
          "en": "No.",
          "zh": "不。"
        },
        {
          "en": "They're in the bathroom!",
          "zh": "他们在浴室里！"
        },
        {
          "en": "What's in the bathroom?",
          "zh": "浴室里有什么？"
        },
        {
          "en": "I see towels, bubbles, and a bathtub!",
          "zh": "我看到毛巾、泡泡和浴缸！"
        },
        {
          "en": "It looks like they're going to have a bath!",
          "zh": "看来他们要去洗澡了！"
        }
      ],
      "guides": [
        {
          "step": "① 观察暖场",
          "action": "先不急着读字，让孩子看纸质书跨页图，说出看到了什么；再播放「整页原音」",
          "en": "It's Bella and Ducky!",
          "zh": "这是贝拉和达基！",
          "note": "第一遍允许只听不说，建立「看图→听→说」的顺序"
        },
        {
          "step": "② 提问互动",
          "action": "指着泡泡提问，等 3～5 秒给孩子思考时间，不会就一起听音频再试",
          "en": "Where are they?",
          "zh": "他们在哪里？",
          "note": "开放式问题没有标准答案，孩子沉默时可以先用中文聊"
        },
        {
          "step": "③ 重点跟读",
          "action": "挑本页最有情绪的句子，重复 2～3 遍，一遍比一遍有表现力",
          "en": "They're in the bathroom!",
          "zh": "他们在浴室里！",
          "note": "感叹句最适合练语气，夸张一点孩子反而记得牢"
        }
      ],
